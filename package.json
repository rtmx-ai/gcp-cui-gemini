{
  "name": "gcp-assured-workloads",
  "version": "0.2.0",
  "description": "IL4/IL5 Assured Workloads boundary plugin for aegis-cli",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gcp-assured-workloads": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check 'src/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "npx cucumber-js tests/features/",
    "test:watch": "vitest watch",
    "precommit": "npm run format && npm run lint && npm run build && npm run test:unit",
    "prepare": "husky"
  },
  "dependencies": {
    "@aegis/infra-sdk": "file:../aegis-infra-sdk",
    "@google-cloud/aiplatform": "^3.0.0",
    "@google-cloud/compute": "^4.0.0",
    "@google-cloud/kms": "^4.0.0",
    "@google-cloud/storage": "^7.0.0",
    "@pulumi/gcp": "^8.0.0",
    "@pulumi/pulumi": "^3.0.0",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
